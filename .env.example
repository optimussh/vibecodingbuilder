GEMINI_API_KEY=

PORT=3000
SESSION_SECRET=change-me-in-local
OPENCODE_BASE_URL=http://127.0.0.1:4096
OPENCODE_BIN=opencode
OPENCODE_MANAGED=true
OPENCODE_PROVIDER_ID=google
OPENCODE_MODEL_ID=gemini-2.0-flash
WORKSPACES_ROOT=./data/workspaces

# Phase 3 RAG (docker compose postgres on 5433)
DATABASE_URL=postgres://vibe:vibe@127.0.0.1:5433/vibe
RAG_ENABLED=true
RAG_TOP_K=5
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=150
EMBEDDING_MODEL=text-embedding-004

# OpenChamber shell — npm run dev:all wires :3001 → OpenCode :4096
OPENCHAMBER_ENABLED=true
OPENCHAMBER_URL=http://127.0.0.1:3001
# Chamber attaches to platform OpenCode (set by start-openchamber.ps1):
# OPENCODE_SKIP_START=true OPENCODE_HOST=http://127.0.0.1:4096

# Governance
DAILY_MESSAGE_QUOTA=200

ADMIN_PASSWORD=admin123
USER1_PASSWORD=user1
USER2_PASSWORD=user2
